{
  "name": "bridge-payments",
  "version": "1.0.0",
  "description": "Secure payment processing backend with Flowless integration",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js",
    "db:migrate": "bun run src/scripts/migrate.ts",
    "db:seed": "bun run src/scripts/seed.ts",
    "db:reset": "bun run src/scripts/reset.ts",
    "init-providers": "bun run src/scripts/init-payment-providers.ts",
    "check-tables": "bun run src/scripts/check-tables.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "validate-config": "bun run src/scripts/validate-config.ts",
    "test-providers": "bun run src/scripts/test-providers.ts"
  },
  "dependencies": {
    "@paypal/sdk-client": "^4.0.197",
    "authorizenet": "^1.0.10",
    "hono": "^4.7.10",
    "hono-rate-limiter": "^0.4.2",
    "kysely": "^0.28.2",
    "nanoid": "^5.1.5",
    "stripe": "^18.1.1",
    "zod": "^3.25.30",
    "pg": "^8.11.0",
    "mysql2": "^3.6.0",
    "kysely-neon": "^1.3.0",
    "@neondatabase/serverless": "^0.7.0",
    "ws": "^8.16.0",
    "kysely-planetscale": "^1.4.0",
    "@planetscale/database": "^1.11.0",
    "undici": "^6.0.0",
    "@libsql/kysely-libsql": "^0.3.0",
    "@libsql/client": "^0.4.0",
    "kysely-d1": "^0.3.0",
    "lru-cache": "^10.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.14",
    "typescript": "^5.8.3",
    "@types/pg": "^8.10.0",
    "@types/ws": "^8.5.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.1.0"
  },
  "keywords": [
    "payments",
    "stripe",
    "paypal",
    "authorize.net",
    "bun",
    "hono",
    "kysely",
    "typescript"
  ],
  "author": "Pubflow Team",
  "license": "MIT"
}