{
  "name": "flowfull-node",
  "version": "0.4.0",
  "description": "Standard architecture backend API template with Flowless",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:node": "tsx watch src/node.ts",
    "dev:deno": "deno run -A src/deno.ts",
    "dev:cf": "wrangler dev",
    "dev:local": "LOCAL_MODE=true bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "build:cf": "bun run build:worker",
    "build:worker": "bun build src/worker.ts --outdir ./dist/worker --target browser --external pg --external mysql2 --external ws --external ioredis",
    "start": "bun run dist/index.js",
    "start:node": "tsx src/node.ts",
    "preview": "tsx src/node.ts",
    "start:deno": "deno run -A src/deno.ts",
    "start:local": "LOCAL_MODE=true bun run dist/index.js",
    "deploy:cf": "wrangler deploy",
    "preview:cf": "wrangler dev --remote",
    "cf:typegen": "wrangler types ./worker-configuration.d.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "validate-config": "bun run src/scripts/validate-config.ts",
    "local-info": "bun run scripts/show-local-info.ts",
    "cleanup-rate-limits": "bun run src/scripts/cleanup-rate-limits.ts",
    "rate-limit-stats": "bun run src/scripts/cleanup-rate-limits.ts stats",
    "token:generate": "bun run scripts/generate-paseto-key.ts",
    "token:test": "bun run scripts/test-trust-tokens.ts",
    "check:deno": "deno cache --no-check src/deno.ts",
    "check:cf": "bun run build:cf",
    "check:worker": "bun run build:worker"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@libsql/client": "^0.4.0",
    "@libsql/kysely-libsql": "^0.3.0",
    "@neondatabase/serverless": "^0.4.3",
    "@planetscale/database": "^1.11.0",
    "croner": "^9.0.0",
    "hono": "^4.7.10",
    "hono-rate-limiter": "^0.4.2",
    "ioredis": "^5.8.2",
    "kysely": "^0.28.2",
    "kysely-d1": "^0.3.0",
    "kysely-neon": "^1.3.0",
    "kysely-planetscale": "^1.4.0",
    "lru-cache": "^11.2.4",
    "mysql2": "^3.6.0",
    "nanoid": "^5.1.5",
    "paseto": "^3.1.4",
    "pg": "^8.11.0",
    "undici": "^6.0.0",
    "ws": "^8.13.0",
    "zod": "^3.25.30"
  },
  "devDependencies": {
    "@types/bun": "^1.2.14",
    "typescript": "^5.8.3",
    "tsx": "^4.21.0",
    "@types/pg": "^8.10.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.1.0",
    "wrangler": "4.101.0"
  },
  "keywords": [
    "backend",
    "api",
    "template",
    "flowless",
    "session-validation",
    "multi-database",
    "bun",
    "hono",
    "kysely",
    "typescript",
    "lfu-cache",
    "zod"
  ],
  "author": "Pubflow, Inc.",
  "license": "Exclusive license - contact legal@pubflow.com for details"
}
