# Server Configuration
PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:3001
HOST=0.0.0.0

# Database Configuration (choose one)
DATABASE_URL=postgresql://username:password@localhost:5432/bridge_payments
# DATABASE_URL=mysql://username:password@localhost:3306/bridge_payments
# DATABASE_URL=libsql://bridge-payments-database.turso.io

# Database Type (optional, auto-detected from URL)
# DATABASE_TYPE=postgresql|mysql|neon|neon-http|planetscale|libsql|d1

# Database Pool Settings
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Renewal System Configuration
RENEWALS_ENABLED=true
RENEWAL_BATCH_SIZE=50
RENEWAL_MAX_CONCURRENT=10
RENEWAL_RETRY_DELAY_MINUTES=60
RENEWAL_MAX_RETRY_ATTEMPTS=3
RENEWAL_DAILY_CRON="0 2 * * *"
RENEWAL_RETRY_CRON="0 * * * *"

# Neon Specific
# NEON_DATABASE_URL=postgresql://username:password@ep-cool-darkness-123456.us-east-1.aws.neon.tech/neondb?sslmode=require

# PlanetScale Specific
# PLANETSCALE_HOST=aws.connect.psdb.cloud
# PLANETSCALE_USERNAME=username
# PLANETSCALE_PASSWORD=password
# PLANETSCALE_SHARED_CONNECTION=false

# LibSQL/Turso Specific
# LIBSQL_AUTH_TOKEN=your_auth_token

# Flowless Integration (auto-detected based on NODE_ENV if not set)
# Development: http://localhost:3000
# Production: https://api.flowless.app
# FLOWLESS_API_URL=http://localhost:3000
BRIDGE_VALIDATION_SECRET=your-shared-secret-key-here
BRIDGE_VALIDATION_TIMEOUT=5000
BRIDGE_RETRY_ATTEMPTS=3

# Session Management
SESSION_VALIDATION_CACHE_TTL=300
SESSION_HEADER_NAME=X-Session-ID
SESSION_COOKIE_NAME=session_id
SESSION_REQUIRE_HTTPS=false

# Guest Checkout Configuration
GUEST_CHECKOUT_ENABLED=true
GUEST_REQUIRE_EMAIL=true
GUEST_REQUIRE_NAME=false
GUEST_REQUIRE_PHONE=false
GUEST_SESSION_DURATION=3600
GUEST_AUTO_CLEANUP=true
GUEST_CLEANUP_INTERVAL=86400
GUEST_DATA_RETENTION_DAYS=30
GUEST_ALLOW_CONVERSION=true
GUEST_MAX_PAYMENTS_PER_EMAIL=5

# Payment Providers
DEFAULT_PAYMENT_PROVIDER=stripe
ENABLED_PROVIDERS=stripe,paypal,authorize_net
PROVIDER_FAILOVER_ENABLED=true

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_PUBLISHABLE_KEY=pk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2023-10-16
STRIPE_CONNECT_ENABLED=false
STRIPE_AUTOMATIC_TAX=false

# PayPal Configuration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_WEBHOOK_ID=your_webhook_id
PAYPAL_BN_CODE=your_bn_code

# Authorize.net Configuration
AUTHORIZE_NET_API_LOGIN=your_api_login_id
AUTHORIZE_NET_TRANSACTION_KEY=your_transaction_key
AUTHORIZE_NET_ENVIRONMENT=sandbox
AUTHORIZE_NET_SIGNATURE_KEY=your_signature_key

# Security Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Session-ID
CORS_CREDENTIALS=true
CORS_MAX_AGE=86400

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_SKIP_SUCCESSFUL=false
RATE_LIMIT_STORE=memory

# Request Security
MAX_REQUEST_SIZE=1048576
REQUEST_TIMEOUT=30000
VALIDATE_CONTENT_TYPE=true
REQUIRE_USER_AGENT=false

# Client Secret Management
CLIENT_SECRET_AUTO_CLEANUP=true
CLIENT_SECRET_CLEANUP_INTERVAL=3600
CLIENT_SECRET_MAX_AGE=86400
CLIENT_SECRET_CLEANUP_ON_SUCCESS=true
CLIENT_SECRET_CLEANUP_ON_FAILURE=false

# Logging & Monitoring
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/bridge-payments.log
LOG_ROTATION_ENABLED=true
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5

# Monitoring & Metrics
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# Development Settings
DEV_MODE=true
DEV_CORS_RELAXED=true
DEV_LOG_REQUESTS=true
DEV_MOCK_PROVIDERS=false
DEV_SEED_DATA=true

# Testing Settings
TEST_DATABASE_URL=libsql://:memory:
TEST_MOCK_FLOWLESS=true
TEST_MOCK_PROVIDERS=true
TEST_TIMEOUT=10000

# Performance Settings
COMPRESSION_ENABLED=true
CACHE_ENABLED=true
CACHE_TTL=300
